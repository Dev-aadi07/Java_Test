package basics;
import java.util.Arrays;

public class ArrayPractice {
	public static int[] insert(int val, int pos, int[] arr) {
		int n = arr.length;
		int temp[] = new int[n+1];
		
		    int j = 0;
		    for (int i = 0; i < arr.length; i++) {
		        if (i == pos) {
		            temp[j++] = val;
		        }
		        temp[j++] = arr[i];
		    }
		return temp;
	}
	
	public static int[] delete(int pos, int[] arr) {
		int n = arr.length;
		int temp[] = new int[n-1];
		int j = 0;
		
		for (int i = 0; i<n; i++) {
			if (i == pos) {
				continue;
			}
			temp[j++] = arr[i];
		}
		
		return temp;
	}
	
	public static void deleteInPlaceUsingVal(int val, int[] arr) {
		int j = 0;
		for (int i=0 ; i<arr.length; i++) {
			if (arr[i] != val) {
				arr[j++] = arr[i];
			}
			
		}
		
		while (j<arr.length) {
			arr[j++] = 0;
		}
	}
	
	public static void deleteInPlace(int pos, int[] arr) {
		for (int i = pos; i<arr.length-1; i++) {
			arr[i] = arr[i+1];
		}
		arr[arr.length-1] = 0;
	}
	
	public static void printArray(int[] arr) {
		for (int ele : arr) {
			System.out.print(ele+" ");
		}
		System.out.println();
	}

	public static void main(String[] args) {
		int[] arr = {1,2,3,4,4,4,4,5};
		
		printArray(arr);		
		int[] temp = new int[arr.length];
		arr = insert(30, 2, arr);
		printArray(arr);
		
//		arr = delete(2, arr);
		
//		deleteInPlace(2, arr);
//		printArray(arr);
		
		deleteInPlaceUsingVal(4, arr);
		printArray(arr);
		
		int[][] a = new int[2][2];
		
	}

}
