package com.Hibernate;

import org.hibernate.Session;
import org.hibernate.SessionFactory;
import org.hibernate.Transaction;
import org.hibernate.cfg.Configuration;

public class Launch {

	
	@SuppressWarnings("deprecation")
	public static void main(String[] args) {
		
		Configuration cfg = new Configuration();
		cfg.configure();
		cfg.addAnnotatedClass(Employee.class); //used when multiple class is there
		SessionFactory sf = cfg.buildSessionFactory();
		Session s = sf.openSession();
		Employee e = new Employee(1, "ali", "ali@gmail.com", "9966");
		
		
		Transaction t = s.beginTransaction();
		s.save(e);
		s.get(Employee.class, 1);
		System.out.println(s.get(Employee.class, 1));
		s.remove(s.get(Employee.class, 1));
		t.commit();
		
	}

}