package interfaceTeaching;

import java.util.function.BiFunction;
import java.util.function.Function;

@FunctionalInterface
interface Printer {
	void print(String name);
}

@FunctionalInterface
interface A{
	void show(String mgs);
}
//interface Bi<T, U> {
//	int apply(T a, U b);
//}

public class LambdaExpre {
	
	static int product (int a, int b) {
			return a*b;
	}
	public void show(String msg) {
		msg = msg.toLowerCase();
		System.out.println(msg);
	}

	public static void main(String[] args) {
		Printer p = (name) -> System.out.println("Hello "+name);
		p.print("Adarsh");
		
		Function<Integer, Double> f = (n) -> Math.sqrt(n);
		System.out.println(f.apply(16));
		
		Function<Integer, Double> f2 = Math::sqrt;
		System.out.println(f2.apply(64));
		
		BiFunction<Integer, Integer, Integer> prod = (a, b)->LambdaExpre.product(a,b);
		BiFunction<Integer, Integer, Integer> product = LambdaExpre::product;
		
		System.out.println("Product: "+prod.apply(5, 4));
		System.out.println("Product: "+product.apply(5, 3));
		
		LambdaExpre le = new LambdaExpre();
		A a = (msg) -> le.show(msg);
		a.show("hELLO");
		
		
	}

}